#!/bin/bash
# AppRun – CS Server Manager AppImage launcher.
#
# The AppImage runtime sets $APPIMAGE (path to the .AppImage file) and
# $APPDIR (mount point of the squashfs filesystem) before executing this
# script.  We provide a fallback so the extracted AppDir can also be
# tested directly without running it through the AppImage runtime.

if [[ -z "${APPDIR}" ]]; then
    APPDIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
fi
export APPDIR

# ── Qt runtime ────────────────────────────────────────────────────────────────
export LD_LIBRARY_PATH="${APPDIR}/usr/lib:${LD_LIBRARY_PATH:-}"

# Bundled Qt plugins take priority.  System Qt6 plugin paths are appended so
# the host desktop's style plugins (e.g. Breeze on KDE Plasma) are also
# visible.
export QT_PLUGIN_PATH="${APPDIR}/usr/plugins:/usr/lib/qt6/plugins:/usr/lib/x86_64-linux-gnu/qt6/plugins:/usr/lib64/qt6/plugins${QT_PLUGIN_PATH:+:${QT_PLUGIN_PATH}}"

# Qt reports QT_QPA_PLATFORM_PLUGIN_PATH in the "not found" warning and uses
# it as the primary search path for platform plugins (wayland, xcb, etc.).
export QT_QPA_PLATFORM_PLUGIN_PATH="${APPDIR}/usr/plugins/platforms"

# ── Launch ────────────────────────────────────────────────────────────────────
exec "${APPDIR}/usr/bin/cs_server_manager" "$@"
